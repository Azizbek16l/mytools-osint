# mytools-osint — API keys
# Copy to .env and fill in. .env is gitignored.

# HaveIBeenPwned — https://haveibeenpwned.com/API/Key  ($3.95/mo)
HIBP_API_KEY=

# Numverify (phone) — https://numverify.com/  (free 100/mo)
NUMVERIFY_API_KEY=

# IPinfo — https://ipinfo.io/  (free 50k/mo)
IPINFO_API_TOKEN=

# Telegram MTProto — https://my.telegram.org/apps
# These belong to YOUR personal Telegram account. The userbot logs in
# as you and queries contacts/usernames. Never share.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_NAME=mytools

# LeakCheck.io (optional) — https://leakcheck.io/
LEAKCHECK_API_KEY=

# dehashed.com (optional)
DEHASHED_EMAIL=
DEHASHED_API_KEY=

# Tuning
HTTP_TIMEOUT_SEC=10
HTTP_CONCURRENCY=40
USERNAME_RETRY=1
