{
  "schema": 1,
  "_": "Email-existence probes. Use is_email_registered modules; many sites send 'forgot password' style probes that respond differently for known vs unknown email. Add carefully — some sites detect and ban scrapers.",
  "sites": [
    {"name": "Spotify",   "method": "POST", "url": "https://spclient.wg.spotify.com/signup/public/v1/account",
      "data": {"validate": 1, "email": "{}"},
      "good_regex": "\"status\"\\s*:\\s*20", "bad_regex": "\"status\"\\s*:\\s*1"},
    {"name": "Adobe",     "method": "POST", "url": "https://auth.services.adobe.com/signin/v2/users/email/status",
      "headers": {"Content-Type": "application/json", "x-ims-clientid": "adobedotcom2"},
      "json": {"email": "{}"},
      "good_regex": "\"status\"\\s*:\\s*\"REGISTERED\"", "bad_regex": "\"status\"\\s*:\\s*\"NOT_FOUND\""},
    {"name": "Lastpass",  "method": "GET", "url": "https://lastpass.com/lmiapi/login/type?username={}&xml=1",
      "good_regex": "\"type\"\\s*:\\s*\"MASTER_PASSWORD\"", "bad_regex": "\"type\"\\s*:\\s*\"UNREGISTERED\""},
    {"name": "Pinterest", "method": "POST", "url": "https://www.pinterest.com/_ngjs/resource/EmailExistsResource/get/",
      "data": {"source_url": "/", "data": "{\"options\":{\"email\":\"{}\"},\"context\":{}}"},
      "good_regex": "\"data\"\\s*:\\s*true", "bad_regex": "\"data\"\\s*:\\s*false"},
    {"name": "Twitter",   "method": "GET", "url": "https://api.twitter.com/i/users/email_available.json?email={}",
      "good_regex": "\"taken\"\\s*:\\s*true", "bad_regex": "\"taken\"\\s*:\\s*false"},
    {"name": "Imgur",     "method": "POST", "url": "https://imgur.com/signin/ajax_email_available",
      "data": {"email": "{}"},
      "good_regex": "\"available\"\\s*:\\s*false", "bad_regex": "\"available\"\\s*:\\s*true"},
    {"name": "Wordpress.com", "method": "POST", "url": "https://wordpress.com/wp-login.php?action=lostpassword",
      "data": {"user_login": "{}", "redirect_to": ""},
      "good_regex": "Check your email", "bad_regex": "Invalid username or email"},
    {"name": "Gravatar",  "method": "GET", "url": "https://en.gravatar.com/{md5}.json",
      "transform": "md5_email",
      "good_status": [200], "bad_status": [404]},
    {"name": "Github",    "method": "GET", "url": "https://api.github.com/search/users?q={}+in:email",
      "good_regex": "\"total_count\"\\s*:\\s*[1-9]", "bad_regex": "\"total_count\"\\s*:\\s*0"},
    {"name": "Dropbox",   "method": "POST", "url": "https://www.dropbox.com/login_email",
      "data": {"email": "{}"},
      "good_regex": "\"is_taken\"\\s*:\\s*true", "bad_regex": "\"is_taken\"\\s*:\\s*false"},
    {"name": "Atlassian", "method": "POST", "url": "https://id.atlassian.com/rest/signup/check-email",
      "json": {"email": "{}"},
      "good_regex": "\"exists\"\\s*:\\s*true", "bad_regex": "\"exists\"\\s*:\\s*false"}
  ]
}
